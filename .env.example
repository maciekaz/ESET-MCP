# ─── Auth mode ─────────────────────────────────────────────────────────────
# env   — single tenant: ESET_USER/ESET_PASSWORD below are used for every
#         request. Default. Works on both stdio and http transports.
# basic — multi tenant: clients send `Authorization: Basic <base64(user:pw)>`
#         on every request, plus optional `X-ESET-Region` (cloud) or
#         `X-ESET-Server-URL` (on-prem PROTECT console). Only valid with
#         ESET_MCP_TRANSPORT=http. ESET_USER/ESET_PASSWORD below become optional.
ESET_AUTH_MODE=env

# ─── ESET API credentials (required when ESET_AUTH_MODE=env) ───────────────
# Use a dedicated API user (NOT your regular console login). Create one in
# ESET PROTECT Hub / ESET Business Account → API users.
ESET_USER=api-user@yourdomain.tld
ESET_PASSWORD=replace-me

# ─── Server behaviour ───────────────────────────────────────────────────────
# RO  — RW tools are visible but blocked before any HTTP request goes out.
# RW  — full access; destructive tools carry destructiveHint=true in MCP annotations.
ESET_MODE=RO

# Default region for the API (eu/de/us/ca/jpn).
# In basic-auth mode, clients can override this per-request with X-ESET-Region.
ESET_REGION=eu

# ─── Deployment kind (cloud vs on-prem ESET PROTECT) ───────────────────────
# cloud   — ESET Connect API at *.eset.systems (the default).
# onprem  — customer-hosted ESET PROTECT console (REST API on port 9443 by
#           default). Authenticates via POST /GetTokens (not /oauth/token).
# In basic-auth mode the client can switch a single request to on-prem by
# sending the X-ESET-Server-URL header — that takes precedence over the
# default below.
ESET_DEPLOYMENT=cloud
# Required only when ESET_DEPLOYMENT=onprem AND ESET_AUTH_MODE=env. In
# basic-auth mode it's the fallback used when X-ESET-Server-URL is absent;
# leave it blank to require the header on every request.
ESET_ONPREM_SERVER_URL=
# Whether to verify the on-prem console's TLS cert. Default ON. Flip to
# false ONLY on trusted intranets where the console serves a self-signed
# cert — disabling verification opens the connection to MITM.
ESET_ONPREM_VERIFY_SSL=true

# ─── Cloudflare Access Service Token (on-prem only) ────────────────────────
# Optional. Use these when the on-prem PROTECT console sits behind
# Cloudflare Access (zero-trust ingress). Both values must be set together
# or both must be empty.
# In basic-auth mode clients can override per-request with:
#   X-ESET-CF-Access-Client-Id: <client-id>.access
#   X-ESET-CF-Access-Client-Secret: <client-secret>
# Cloud requests never carry these headers (ESET Connect is a public SaaS
# and is not fronted by anyone's Cloudflare Access).
ESET_ONPREM_CF_ACCESS_CLIENT_ID=
ESET_ONPREM_CF_ACCESS_CLIENT_SECRET=

# ─── MCP transport ─────────────────────────────────────────────────────────
# stdio — for Claude Desktop / Claude Code (local stdin/stdout JSON-RPC).
# http  — Streamable HTTP per MCP spec 2025-11-25; exposes an HTTP endpoint.
ESET_MCP_TRANSPORT=stdio

# Used only when ESET_MCP_TRANSPORT=http:
ESET_MCP_HTTP_HOST=127.0.0.1
ESET_MCP_HTTP_PORT=8765

# ─── Response shaping (LLM context window protection) ──────────────────────
# Per-call payload byte cap. Large `list_*` results (e.g. pageSize=1000)
# can return >200 KB ≈ 50 k tokens — enough to overflow a model's context.
# When a response exceeds this, the server keeps every top-level field
# (especially `nextPageToken`) intact, trims items from the longest list,
# and attaches a `_capped` metadata block telling the agent how to continue.
# Set to 0 to disable (not recommended).
ESET_MCP_RESPONSE_BYTES_MAX=100000

# ─── Optional logging level ────────────────────────────────────────────────
ESET_LOG_LEVEL=INFO

# ─── Observability (logs + metrics) ────────────────────────────────────────
# Log output format:
#   text - human-readable single line per record (default, good for dev)
#   json - JSON Lines, one self-contained object per line (recommended in
#          prod - Loki/Vector/Fluent Bit/Datadog all parse it out of the box)
ESET_MCP_LOG_FORMAT=text

# Prometheus /metrics endpoint (HTTP transport only). Opt-in. When true,
# the metrics route is mounted on the same uvicorn server but bypasses
# basic-auth (Prometheus scrapers don't speak Basic auth; /metrics carries
# no secrets). Protect at the network/firewall layer instead.
# Requires `pip install eset-mcp[metrics]` for the prometheus_client dep.
ESET_MCP_METRICS_ENABLED=false
ESET_MCP_METRICS_PATH=/metrics

# ─── Production deployment (docker compose --profile prod) ─────────────────
# Public domain Caddy will request a Let's Encrypt cert for. Must point at
# the host running docker-compose. Only used by the `prod` profile.
ESET_PUBLIC_DOMAIN=eset-mcp.example.com
# Email Let's Encrypt uses for cert expiry notifications.
ESET_ACME_EMAIL=ops@example.com
